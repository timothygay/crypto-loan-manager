{
  "version": 2,
  "regions": ["cdg1"],
  "functions": {
    "api/prices.js": {
      "maxDuration": 10
    },
    "api/bybit-trs.js": {
      "maxDuration": 15
    },
    "api/trs-sheets.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ]
}
